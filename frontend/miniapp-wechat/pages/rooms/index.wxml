<view class="page-shell safe-bottom">
  <view class="page-hero home-hero">
    <view class="page-eyebrow">首页</view>
    <view class="page-title">已绑定房间</view>

    <view class="home-hero__stats">
      <view class="home-stat-card">
        <view class="home-stat-card__label">绑定房间</view>
        <view class="home-stat-card__value">{{rooms.length}}</view>
      </view>
      <view class="home-stat-card home-stat-card--accent">
        <view class="home-stat-card__label">待缴账单</view>
        <view class="home-stat-card__value">{{unpaidBillCount}}</view>
      </view>
    </view>
  </view>

  <view class="panel action-panel action-panel--summary">
    <view class="action-panel__label">待付金额</view>
    <view class="action-panel__value">¥ {{unpaidAmountText}}</view>
    <view class="action-panel__hint">当前绑定房间待支付总额</view>
  </view>

  <view wx:if="{{loading}}" class="panel state-card">
    <view class="state-title">正在加载</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="panel state-card">
    <view class="state-title text-danger">加载失败</view>
    <view class="state-desc">{{errorMessage}}</view>
    <button class="button-inline" bindtap="fetchRooms">重新加载</button>
  </view>

  <view wx:elif="{{!rooms.length}}" class="panel state-card">
    <view class="state-title">暂无已绑定房间</view>
    <view class="state-desc">请前往“我的”完成房间绑定后，再查看对应账单。</view>
    <button class="button-inline" bindtap="openProfile">去绑定房间</button>
  </view>

  <view wx:else class="list-stack">
    <view wx:for="{{rooms}}" wx:key="roomId" class="panel card-stack room-home-card">
      <view class="room-home-card__top">
        <view class="card-kicker">房间 {{index + 1}}</view>
      </view>
      <view class="room-home-card__title">{{item.roomLabel}}</view>
      <view class="metric-grid room-home-card__metrics">
        <view class="metric-card">
          <view class="metric-label">面积</view>
          <view class="metric-value">{{item.areaText}}</view>
        </view>
      </view>
      <button class="button-primary" data-room-id="{{item.roomId}}" bindtap="openRoomBills">查看该房间账单</button>
    </view>
  </view>
</view>
