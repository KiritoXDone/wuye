.agent-im-page {
  min-height: 100vh;
  padding: 0 var(--page-padding) var(--page-padding);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.agent-topbar {
  position: sticky;
  top: 0;
  z-index: 5;
  padding-top: calc(var(--space-3) + env(safe-area-inset-top));
  padding-bottom: var(--space-2);
  background: var(--page-background);
}

.agent-chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
  padding: var(--space-2) 0;
}

.agent-chat-heading {
  min-width: 0;
}

.agent-chat-title {
  color: var(--color-text);
  font-size: 36rpx;
  font-weight: 700;
  line-height: var(--line-height-tight);
}

.agent-chat-status {
  margin-top: 8rpx;
  color: var(--color-text-muted);
  font-size: var(--font-size-caption);
}

.agent-header-action {
  flex-shrink: 0;
}

.agent-system-note {
  padding: var(--space-2) var(--space-3);
  margin-top: var(--space-2);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-caption);
  text-align: left;
}

.agent-session-strip {
  white-space: nowrap;
  margin-top: var(--space-1);
}

.agent-session-strip__inner {
  display: inline-flex;
  gap: var(--space-2);
  padding: 0 0 var(--space-1);
}

.agent-session-chip {
  width: 248rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  border: 1rpx solid var(--color-border);
  background: var(--color-surface-muted);
  box-shadow: var(--shadow-soft);
  box-sizing: border-box;
}

.agent-session-chip--active {
  background: var(--button-primary-bg);
  border-color: transparent;
  box-shadow: var(--button-primary-shadow);
}

.agent-session-chip__title {
  color: var(--color-text);
  font-size: var(--font-size-caption);
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.agent-session-chip--active .agent-session-chip__title,
.agent-session-chip--active .agent-session-chip__desc {
  color: var(--color-text-contrast);
}

.agent-session-chip__desc {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.agent-system-note--danger {
  background: var(--color-danger-soft);
  color: var(--color-danger);
}

.agent-system-note--success {
  background: var(--color-success-soft);
  color: var(--color-success);
}

.agent-thread-shell {
  flex: 1;
  min-height: 0;
}

.agent-message-list {
  flex: 1;
  min-height: 0;
  padding: var(--space-3) 0 calc(var(--space-4) + 120rpx);
}

.agent-empty-state {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  text-align: center;
}

.agent-empty-badge {
  padding: 10rpx 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-pill);
  color: var(--color-text-muted);
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.agent-empty-title {
  color: var(--color-text);
  font-size: var(--font-size-subtitle);
  font-weight: 700;
}

.agent-empty-desc {
  max-width: 32em;
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.agent-message-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  margin-bottom: var(--space-4);
}

.agent-message-row--user {
  justify-content: flex-end;
}

.agent-message-row--assistant {
  justify-content: flex-start;
}

.agent-message-avatar {
  width: 52rpx;
  height: 52rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 50%;
  background: var(--color-surface-muted);
  color: var(--color-text-secondary);
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-bottom: 8rpx;
}

.agent-message-content {
  display: flex;
  flex-direction: column;
  max-width: calc(100% - 68rpx);
}

.agent-message-content--user {
  align-items: flex-end;
}

.agent-message-content--assistant {
  align-items: flex-start;
}

.agent-message-role {
  margin: 0 10rpx 10rpx;
  color: var(--color-text-muted);
  font-size: 22rpx;
}

.agent-message-role--user {
  text-align: right;
}

.agent-message-bubble {
  width: 100%;
  padding: var(--space-3);
  border-radius: 28rpx;
  box-sizing: border-box;
}

.agent-message-bubble--user {
  background: var(--button-primary-bg);
  color: var(--button-primary-text);
  box-shadow: var(--button-primary-shadow);
  border-bottom-right-radius: 10rpx;
}

.agent-message-bubble--assistant {
  background: var(--color-surface);
  color: var(--color-text);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
  border-bottom-left-radius: 10rpx;
}

.agent-message-text {
  white-space: pre-wrap;
  word-break: break-word;
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.agent-streaming-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: var(--space-2);
  border-radius: 50%;
  background: var(--color-text-muted);
  animation: agent-pulse 1s ease-in-out infinite;
}

@keyframes agent-pulse {
  0%, 100% { opacity: 0.35; }
  50% { opacity: 1; }
}

.agent-message-meta {
  margin-top: var(--space-2);
  color: var(--color-text-muted);
  font-size: var(--font-size-caption);
}

.agent-card {
  margin-top: var(--space-2);
  padding: var(--space-3);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  background: var(--color-surface-muted);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
}

.agent-card--muted {
  background: var(--color-surface-muted);
}

.agent-card--warn {
  border-color: var(--color-warning-border);
  background: var(--color-warning-soft);
}

.agent-card--success {
  border-color: var(--color-success);
  background: var(--color-success-soft);
}

.agent-card-title {
  margin-bottom: var(--space-2);
  color: var(--color-text);
  font-size: var(--font-size-caption);
  font-weight: 700;
}

.agent-card-text {
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.compact-info-list {
  gap: var(--space-2);
}

.agent-confirm-card {
  margin-top: var(--space-3);
  padding-top: var(--space-2);
  border-top: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
}

.agent-confirm-title {
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
}

.agent-confirm-button {
  min-height: 68rpx;
}

.agent-composer {
  display: flex;
  align-items: flex-end;
  gap: var(--space-2);
}

.agent-composer__input {
  flex: 2;
  min-height: 88rpx;
  max-height: 240rpx;
  margin: 0;
}

.agent-composer__send {
  flex: 1;
  min-height: 88rpx;
  max-width: 168rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  align-self: center;
}
