.agent-im-page {
  min-height: 100vh;
  padding: var(--page-padding);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.agent-chat-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-1);
}

.agent-chat-title {
  color: var(--color-text);
  font-size: var(--font-size-title);
  font-weight: 700;
  line-height: var(--line-height-tight);
}

.agent-chat-status {
  margin-top: 8rpx;
  color: var(--color-text-muted);
  font-size: var(--font-size-caption);
}

.agent-system-note {
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-pill);
  font-size: var(--font-size-caption);
  text-align: center;
}

.agent-session-strip {
  white-space: nowrap;
}

.agent-session-strip__inner {
  display: inline-flex;
  gap: var(--space-2);
  padding-bottom: var(--space-1);
}

.agent-session-chip {
  width: 280rpx;
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border);
  background: var(--color-surface-muted);
  box-sizing: border-box;
}

.agent-session-chip--active {
  background: var(--color-text);
  border-color: var(--color-text);
}

.agent-session-chip__title {
  color: var(--color-text);
  font-size: var(--font-size-caption);
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.agent-session-chip--active .agent-session-chip__title,
.agent-session-chip--active .agent-session-chip__desc {
  color: var(--color-text-contrast);
}

.agent-session-chip__desc {
  margin-top: 8rpx;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.agent-system-note--danger {
  background: var(--color-danger-soft);
  color: var(--color-danger);
}

.agent-system-note--success {
  background: var(--color-success-soft);
  color: var(--color-success);
}

.agent-message-list {
  flex: 1;
  min-height: 0;
  padding: var(--space-2) 0;
}

.agent-empty-state {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  text-align: center;
}

.agent-empty-title {
  color: var(--color-text);
  font-size: var(--font-size-subtitle);
  font-weight: 700;
}

.agent-empty-desc {
  max-width: 32em;
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.agent-message-row {
  display: flex;
  margin-bottom: var(--space-3);
}

.agent-message-row--user {
  justify-content: flex-end;
}

.agent-message-row--assistant {
  justify-content: flex-start;
}

.agent-message-bubble {
  max-width: 82%;
  padding: var(--space-3);
  border-radius: 28rpx;
  box-sizing: border-box;
}

.agent-message-bubble--user {
  background: var(--color-text);
  color: var(--color-text-contrast);
  border-bottom-right-radius: 10rpx;
}

.agent-message-bubble--assistant {
  background: var(--color-surface);
  color: var(--color-text);
  border: 1rpx solid var(--color-border);
  border-bottom-left-radius: 10rpx;
}

.agent-message-text {
  white-space: pre-wrap;
  word-break: break-word;
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.agent-streaming-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: var(--space-2);
  border-radius: 50%;
  background: var(--color-text-muted);
  animation: agent-pulse 1s ease-in-out infinite;
}

@keyframes agent-pulse {
  0%, 100% { opacity: 0.35; }
  50% { opacity: 1; }
}

.agent-message-meta {
  margin-top: var(--space-2);
  color: var(--color-text-muted);
  font-size: var(--font-size-caption);
}

.agent-card {
  margin-top: var(--space-2);
  padding: var(--space-3);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  background: var(--color-surface-muted);
}

.agent-card--muted {
  background: var(--color-surface-muted);
}

.agent-card--warn {
  border-color: #f59e0b;
  background: #fff7ed;
}

.agent-card--success {
  border-color: var(--color-success);
  background: var(--color-success-soft);
}

.agent-card-title {
  margin-bottom: var(--space-2);
  color: var(--color-text);
  font-size: var(--font-size-caption);
  font-weight: 700;
}

.agent-card-text {
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.compact-info-list {
  gap: var(--space-2);
}

.agent-confirm-card {
  margin-top: var(--space-3);
  padding-top: var(--space-2);
  border-top: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
}

.agent-confirm-title {
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
}

.agent-confirm-button {
  min-height: 68rpx;
}

.agent-composer {
  display: flex;
  align-items: flex-end;
  gap: var(--space-2);
}

.agent-composer__input {
  flex: 1;
  min-height: 88rpx;
  max-height: 240rpx;
  margin: 0;
}

.agent-composer__send {
  flex-shrink: 0;
  min-height: 88rpx;
  padding: 0 var(--space-4);
}