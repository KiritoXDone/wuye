.result-hero {
  align-items: center;
  text-align: center;
}

.result-hero__eyebrow {
  margin-left: auto;
  margin-right: auto;
}

.result-hero__title,
.result-hero__subtitle {
  max-width: none;
}


.result-hero__meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-3);
}

.result-meta-card .info-value {
  max-width: 18em;
}
