<view class="page-shell safe-bottom">
  <view class="page-hero result-hero result-hero--{{paymentStatus}}">
    <view class="result-icon result-icon--{{paymentStatus}}">{{statusEmoji}}</view>
    <view class="page-eyebrow result-hero__eyebrow">支付状态</view>
    <view class="page-title result-hero__title">{{statusTitle}}</view>
    <view class="page-subtitle result-hero__subtitle">{{statusDescription}}</view>
    <view class="result-hero__meta">
      <view class="status-chip status-chip--{{paymentStatus}}">{{paymentStatusLabel}}</view>
      <view wx:if="{{paymentStatus === 'PAYING'}}" class="summary-pill">
        <view class="summary-pill__label">自动刷新</view>
        <view class="summary-pill__value">{{pollAttempt}} / {{pollLimit}}</view>
      </view>
    </view>
  </view>

  <view class="panel card-stack result-meta-card">
    <view class="section-heading">
      <view>
        <view class="section-title">支付信息</view>
        <view class="section-subtitle">这里可以继续核对支付单号、账单号和凭证状态。</view>
      </view>
    </view>
    <view class="info-list">
      <view class="info-row">
        <view class="info-key">支付单号</view>
        <view class="info-value">{{payOrderNo}}</view>
      </view>
      <view class="info-row">
        <view class="info-key">账单编号</view>
        <view class="info-value">{{billIdText}}</view>
      </view>
      <view class="info-row">
        <view class="info-key">支付时间</view>
        <view class="info-value">{{paidAtText}}</view>
      </view>
      <view wx:if="{{rewardIssuedVisible}}" class="info-row">
        <view class="info-key">奖励券发放</view>
        <view class="info-value">{{rewardIssuedCount}} 张</view>
      </view>
      <view class="info-row">
        <view class="info-key">电子凭证</view>
        <view class="info-value">{{voucherIssued ? '已生成' : '待生成'}}</view>
      </view>
      <view wx:if="{{paymentStatus === 'PAYING'}}" class="info-row">
        <view class="info-key">轮询进度</view>
        <view class="info-value">{{pollAttempt}} / {{pollLimit}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{rewardIssuedVisible}}" class="panel card-stack">
    <view class="section-title">奖励发放结果</view>
    <view class="surface-note">{{rewardIssuedText}}</view>
  </view>

  <view wx:if="{{errorMessage}}" class="panel state-card">
    <view class="state-title text-danger">查询失败</view>
    <view class="state-desc">{{errorMessage}}</view>
  </view>

  <view class="panel card-stack">
    <view class="section-title">接下来可以做什么</view>
    <view wx:if="{{paymentStatus === 'SUCCESS'}}" class="surface-note">缴费完成后，可继续查看电子凭证，或返回账单详情再次核对。</view>
    <view wx:elif="{{paymentStatus === 'PAYING'}}" class="surface-note">结果仍在确认中，页面会自动刷新；如果你刚完成支付，也可以手动刷新一次。</view>
    <view wx:else class="surface-note">本次支付尚未完成，你可以返回账单详情重新确认金额并再次发起支付。</view>
  </view>

  <view class="fixed-action-bar button-row">
    <button wx:if="{{paymentStatus === 'SUCCESS' && voucherIssued}}" class="button-primary" bindtap="openVoucher">查看电子凭证</button>
    <button wx:elif="{{paymentStatus === 'FAILED' || paymentStatus === 'CLOSED'}}" class="button-primary" bindtap="openBillDetail">返回账单重新支付</button>
    <button wx:else class="button-primary" bindtap="refreshStatus" loading="{{loading}}" disabled="{{loading}}">立即刷新状态</button>
    <button wx:if="{{paymentStatus === 'SUCCESS' && voucherIssued}}" class="button-secondary" bindtap="openBillDetail">返回账单详情</button>
    <button wx:elif="{{paymentStatus === 'FAILED' || paymentStatus === 'CLOSED'}}" class="button-secondary" bindtap="refreshStatus" loading="{{loading}}" disabled="{{loading}}">再查一次结果</button>
    <button wx:else class="button-secondary" bindtap="openBillDetail">返回账单详情</button>
    <button class="button-ghost" bindtap="backToRooms">回到我的房间</button>
  </view>
</view>
