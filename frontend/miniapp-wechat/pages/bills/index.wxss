.page-title {
  max-width: 12em;
}

.bills-filter-card__chips {
  margin-top: var(--space-1);
}

.bill-list-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 251, 255, 0.95) 100%);
}

.bill-list-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-2);
}

.bill-list-card__amount-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--space-3);
}

.bill-list-card__amount {
  margin-top: var(--space-1);
}

.bill-period-chip {
  padding: 12rpx 20rpx;
  border: 1rpx solid var(--color-primary-border);
  border-radius: var(--radius-pill);
  background: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: var(--font-size-caption);
  font-weight: 600;
}

.bill-list-card__metrics {
  margin-top: var(--space-1);
}

.bill-list-card__metric-value {
  font-size: var(--font-size-subtitle);
}

.bill-list-card__note {
  margin-top: var(--space-1);
}
