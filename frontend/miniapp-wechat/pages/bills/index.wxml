<view class="page-shell safe-bottom">
  <view class="page-hero bills-hero">
    <view class="page-eyebrow">账单</view>
    <view class="page-title">全部账单</view>
  </view>

  <view class="panel card-stack bills-filter-card">
    <view class="section-heading">
      <view class="section-title">账单筛选</view>
      <view class="summary-pill">
        <view class="summary-pill__label">当前显示</view>
        <view class="summary-pill__value">{{displayBills.length}} 笔</view>
      </view>
    </view>
    <picker mode="selector" range="{{roomOptions}}" range-key="roomLabel" value="{{selectedRoomIndex}}" bindchange="handleRoomChange">
      <view class="picker-field">
        <view class="picker-field__label">房间筛选</view>
        <view class="picker-field__value">{{roomOptions[selectedRoomIndex].roomLabel}}</view>
      </view>
    </picker>
    <view class="chip-row bills-filter-card__chips">
      <view wx:for="{{statusOptions}}" wx:key="value" class="pill {{statusFilter === item.value ? 'pill-active' : ''}}" data-status="{{item.value}}" bindtap="handleStatusChange">
        {{item.label}}
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="panel state-card">
    <view class="state-title">正在加载</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="panel state-card">
    <view class="state-title text-danger">账单加载失败</view>
    <view class="state-desc">{{errorMessage}}</view>
    <button class="button-inline" bindtap="fetchBills">重新加载</button>
  </view>

  <view wx:elif="{{!displayBills.length}}" class="panel state-card">
    <view class="state-title">暂无账单</view>
  </view>

  <view wx:else class="list-stack">
    <view wx:for="{{displayBills}}" wx:key="billId" class="panel card-stack bill-list-card">
      <view class="bill-list-card__top">
        <view>
          <view class="card-kicker">{{item.roomLabel}} · {{item.period}}</view>
          <view class="bill-card-title">{{item.feeTypeLabel}}</view>
        </view>
        <view class="status-chip status-chip--{{item.status}}">{{item.statusLabel}}</view>
      </view>

      <view class="bill-list-card__amount-row">
        <view>
          <view class="meta-label">应缴金额</view>
          <view class="amount-primary bill-list-card__amount">¥ {{item.amountDueText}}</view>
        </view>
        <view class="bill-period-chip">{{item.period}}</view>
      </view>

      <view class="metric-grid bill-list-card__metrics">
        <view class="metric-card">
          <view class="metric-label">房间</view>
          <view class="metric-value bill-list-card__metric-value">{{item.roomLabel}}</view>
        </view>
        <view class="metric-card">
          <view class="metric-label">到期日</view>
          <view class="metric-value bill-list-card__metric-value">{{item.dueDateText}}</view>
        </view>
      </view>

      <button class="button-primary" data-bill-id="{{item.billId}}" bindtap="openBillDetail">{{item.status === 'PAID' ? '查看详情' : '立即支付'}}</button>
    </view>
  </view>
</view>
