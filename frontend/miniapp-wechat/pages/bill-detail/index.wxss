.detail-hero {
  padding-bottom: var(--space-5);
}

.detail-hero__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
}

.detail-hero__title {
  max-width: 12em;
}

.detail-hero__amount-label {
  margin-top: var(--space-3);
  color: var(--color-text-muted);
  font-size: var(--font-size-caption);
}

.detail-hero .amount-primary {
  margin-top: var(--space-1);
}

.detail-hero__amount-note {
  margin-top: var(--space-1);
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.pay-summary-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(244, 249, 255, 0.96) 100%);
}

.pay-summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-2);
}

.pay-summary-item {
  padding: var(--space-3);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-surface-strong);
  box-sizing: border-box;
}

.pay-summary-item--emphasis {
  grid-column: 1 / -1;
  border-color: var(--color-primary-border);
  background: var(--gradient-hero);
}

.pay-summary-item__value {
  margin-top: var(--space-1);
}

.pay-summary-item__value--emphasis {
  color: var(--color-primary-deep);
}

.coupon-list {
  gap: var(--space-2);
}

.coupon-option {
  width: 100%;
  padding: var(--space-3);
  border-color: var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--color-surface-strong);
  box-sizing: border-box;
}

.coupon-option--active {
  border-color: var(--color-primary-border);
  background: var(--gradient-hero);
  color: var(--color-primary);
}

.coupon-option__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
}

.coupon-option__name {
  color: var(--color-text);
  font-size: var(--font-size-subtitle);
  font-weight: 600;
}

.coupon-option__amount {
  color: var(--color-primary-deep);
  font-size: var(--font-size-subtitle);
  font-weight: 700;
}

.coupon-option__meta {
  margin-top: var(--space-1);
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.channel-row {
  margin-top: var(--space-1);
}

.line-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.line-item__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
}

.line-item__meta {
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.detail-info-card__value {
  font-size: var(--font-size-subtitle);
}

.action-summary-row {
  align-items: flex-end;
}

.action-summary-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--space-2);
}

.action-summary-note {
  padding: var(--space-2) var(--space-3);
  text-align: right;
}
