<view class="page-shell safe-bottom">
  <view wx:if="{{loading}}" class="panel state-card">
    <view class="state-title">正在加载账单详情</view>
    <view class="state-desc">正在为你同步账单、优惠券与支付信息。</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="panel state-card">
    <view class="state-title text-danger">账单详情加载失败</view>
    <view class="state-desc">{{errorMessage}}</view>
    <button class="button-inline" bindtap="fetchBillDetail">重新加载</button>
  </view>

  <block wx:elif="{{billDetail}}">
    <view class="page-hero detail-hero">
      <view class="detail-hero__top">
        <view>
          <view class="page-eyebrow">账单详情</view>
          <view class="page-title detail-hero__title">{{billDetail.feeTypeLabel}}</view>
          <view class="page-subtitle">{{billDetail.roomLabel}} · {{billDetail.periodText}}</view>
        </view>
        <view class="status-chip status-chip--{{billDetail.status}}">{{billDetail.statusLabel}}</view>
      </view>

      <view class="detail-hero__amount-label">{{billDetail.status === 'PAID' ? '账单金额' : '当前应付'}}</view>
      <view class="amount-primary">¥ {{billDetail.status === 'PAID' ? billDetail.amountDueText : payAmountText}}</view>
      <view class="detail-hero__amount-note">应收 ¥ {{billDetail.amountDueText}}<text wx:if="{{selectedCouponInstanceId}}"> · 已优惠 ¥ {{discountAmountText}}</text></view>
    </view>

    <view class="panel card-stack pay-summary-card">
      <view class="section-heading">
        <view class="section-title">支付摘要</view>
        <view wx:if="{{selectedCouponName}}" class="summary-pill">
          <view class="summary-pill__label">已选优惠</view>
          <view class="summary-pill__value">{{selectedCouponName}}</view>
        </view>
      </view>

      <view wx:if="{{billDetail.feeType === 'PROPERTY' && billDetail.status !== 'PAID'}}" class="annual-payment-row">
        <view class="section-title annual-payment-title">按年缴纳物业费</view>
        <switch color="var(--color-primary)" checked="{{annualPayment}}" bindchange="handleAnnualPaymentChange" />
      </view>

      <view class="pay-summary-grid">
        <view class="pay-summary-item">
          <view class="metric-label">应收金额</view>
          <view class="amount-secondary pay-summary-item__value">¥ {{billDetail.amountDueText}}</view>
        </view>
        <view class="pay-summary-item">
          <view class="metric-label">优惠金额</view>
          <view class="amount-secondary pay-summary-item__value">¥ {{discountAmountText}}</view>
        </view>
        <view class="pay-summary-item pay-summary-item--emphasis">
          <view class="metric-label">实付金额</view>
          <view class="amount-secondary pay-summary-item__value pay-summary-item__value--emphasis">¥ {{payAmountText}}</view>
        </view>
      </view>
    </view>

    <view class="panel card-stack">
      <view class="section-heading">
        <view class="section-title">优惠券</view>
      </view>
      <view wx:if="{{billDetail.status === 'PAID'}}" class="surface-note">本账单已完成支付，无需再选择优惠券。</view>
      <view wx:elif="{{annualPayment}}" class="surface-note">按年缴纳模式下不支持选择优惠券。</view>
      <view wx:elif="{{billDetail.availableCoupons.length}}" class="list-stack coupon-list">
        <view class="coupon-chip coupon-option {{selectedCouponInstanceId === 0 ? 'coupon-option--active' : ''}}" bindtap="clearCouponSelection">
          <view class="coupon-option__header">
            <view class="coupon-option__name">不使用优惠券</view>
            <view class="coupon-option__amount">保持原金额</view>
          </view>
        </view>
        <view
          wx:for="{{billDetail.availableCoupons}}"
          wx:key="couponInstanceId"
          class="coupon-chip coupon-option {{selectedCouponInstanceId === item.couponInstanceId ? 'coupon-option--active' : ''}}"
          data-coupon-id="{{item.couponInstanceId}}"
          bindtap="handleCouponSelect"
        >
          <view class="coupon-option__header">
            <view>
              <view class="coupon-option__name">{{item.name}}</view>
              <view class="coupon-option__meta">{{item.templateCode}}</view>
            </view>
            <view class="coupon-option__amount">¥ {{item.discountAmountText}}</view>
          </view>
          <view class="coupon-option__meta">截止 {{item.expiresAtText}}</view>
        </view>
      </view>
      <view wx:else class="surface-note">当前账单暂无可用券。</view>
    </view>

    <view class="panel card-stack">
      <view class="section-heading">
        <view class="section-title">支付方式</view>
      </view>
      <view class="chip-row channel-row">
        <view class="pill {{selectedChannel === 'WECHAT' ? 'pill-active' : ''}}" data-channel="WECHAT" bindtap="handleChannelSelect">微信支付</view>
        <view class="pill {{selectedChannel === 'ALIPAY' ? 'pill-active' : ''}}" data-channel="ALIPAY" bindtap="handleChannelSelect">支付宝支付</view>
      </view>
      <view class="info-list">
        <view class="info-row">
          <view class="info-key">当前房间</view>
          <view class="info-value">{{billDetail.roomLabel}}</view>
        </view>
        <view class="info-row">
          <view class="info-key">当前账期</view>
          <view class="info-value">{{billDetail.periodText}}</view>
        </view>
        <view class="info-row">
          <view class="info-key">支付渠道</view>
          <view class="info-value">{{selectedChannel === 'ALIPAY' ? '支付宝' : '微信支付'}}</view>
        </view>
      </view>
    </view>

    <view class="panel card-stack">
      <view class="section-heading">
        <view class="section-title">账单明细</view>
      </view>
      <view wx:for="{{billDetail.billLines}}" wx:key="lineNo" class="line-item">
        <view class="line-item__top">
          <view class="bill-card-title">{{item.itemName}}</view>
          <view class="amount-secondary">¥ {{item.lineAmountText}}</view>
        </view>
        <view class="line-item__meta">单价 {{item.unitPriceText}} × 数量 {{item.quantityText}}</view>
        <view wx:if="{{item.extSummary}}" class="line-item__meta">{{item.extSummary}}</view>
        <view wx:if="{{item.showDivider}}" class="divider"></view>
      </view>
    </view>

    <view class="panel card-stack">
      <view class="section-heading">
        <view class="section-title">账单信息</view>
      </view>
      <view class="metric-grid">
        <view class="metric-card">
          <view class="metric-label">账单编号</view>
          <view class="metric-value detail-info-card__value">{{billDetail.billNo}}</view>
        </view>
        <view class="metric-card">
          <view class="metric-label">到期日</view>
          <view class="metric-value detail-info-card__value">{{billDetail.dueDateText}}</view>
        </view>
      </view>
    </view>

    <view class="fixed-action-bar button-row">
      <view class="info-row action-summary-row">
        <view>
          <view class="info-key">{{billDetail.status === 'PAID' ? '账单金额' : '待支付'}}</view>
          <view class="amount-secondary">¥ {{billDetail.status === 'PAID' ? billDetail.amountDueText : payAmountText}}</view>
        </view>
        <view class="action-summary-side">
          <view wx:if="{{billDetail.status === 'PAID'}}" class="status-chip status-chip--PAID">已支付</view>
        </view>
      </view>

        <button wx:if="{{billDetail.status !== 'PAID'}}" class="button-primary" bindtap="handlePay" loading="{{paying}}" disabled="{{paying || couponValidating}}">{{annualPayment ? '按年支付' : '立即支付'}}</button>
      <button wx:else class="button-secondary" bindtap="openPaymentResultFromPaid">查看支付结果</button>
      <button wx:if="{{billDetail.status === 'PAID' && (latestPayOrderNo || entryPayOrderNo)}}" class="button-ghost" bindtap="openVoucher">查看电子凭证</button>
    </view>
  </block>
</view>
