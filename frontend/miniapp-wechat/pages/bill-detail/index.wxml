<view class="page-shell safe-bottom">
  <view wx:if="{{loading}}" class="panel state-card">
    <view class="state-title">正在加载账单详情</view>
    <view class="state-desc">正在调用 <text>/api/v1/bills/{{billId}}</text>。</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="panel state-card">
    <view class="state-title text-danger">账单详情加载失败</view>
    <view class="state-desc">{{errorMessage}}</view>
    <button class="button-inline" bindtap="fetchBillDetail">重新加载</button>
  </view>

  <block wx:elif="{{billDetail}}">
    <view class="panel card-stack">
      <view class="info-row">
        <view>
          <view class="section-title">{{billDetail.feeTypeLabel}}</view>
          <view class="section-subtitle">房间 {{billDetail.roomLabel}} · 账期 {{billDetail.periodText}}</view>
        </view>
        <view class="status-chip status-chip--{{billDetail.status}}">{{billDetail.statusLabel}}</view>
      </view>

      <view class="amount-primary">¥ {{billDetail.amountDueText}}</view>

      <view class="meta-grid">
        <view class="meta-item">
          <view class="meta-label">账单编号</view>
          <view class="meta-value">{{billDetail.billNo}}</view>
        </view>
        <view class="meta-item">
          <view class="meta-label">到期日</view>
          <view class="meta-value">{{billDetail.dueDateText}}</view>
        </view>
      </view>
    </view>

    <view class="panel card-stack">
      <view class="section-title">账单明细</view>
      <view wx:for="{{billDetail.billLines}}" wx:key="lineNo" class="card-stack">
        <view class="info-row">
          <view class="bill-card-title">{{item.itemName}}</view>
          <view class="amount-secondary">¥ {{item.lineAmountText}}</view>
        </view>
        <view class="text-muted">单价 {{item.unitPriceText}} × 数量 {{item.quantityText}}</view>
        <view wx:if="{{item.extSummary}}" class="text-muted">{{item.extSummary}}</view>
        <view wx:if="{{item.showDivider}}" class="divider"></view>
      </view>
    </view>

    <view class="panel card-stack">
      <view class="section-title">可用券</view>
      <view wx:if="{{billDetail.availableCoupons.length}}" class="card-stack">
        <view class="chip-row">
          <view class="pill {{selectedCouponInstanceId === 0 ? 'pill-active' : ''}}" bindtap="clearCouponSelection">不使用优惠券</view>
          <view
            wx:for="{{billDetail.availableCoupons}}"
            wx:key="couponInstanceId"
            class="coupon-chip coupon-option {{selectedCouponInstanceId === item.couponInstanceId ? 'coupon-option--active' : ''}}"
            data-coupon-id="{{item.couponInstanceId}}"
            bindtap="handleCouponSelect"
          >
            <view class="coupon-option__name">{{item.name}}</view>
            <view>{{item.templateCode}} · ¥{{item.discountAmountText}} · 截止 {{item.expiresAtText}}</view>
          </view>
        </view>
        <view class="text-muted">{{couponValidating ? '正在校验优惠券，请稍候…' : couponHint}}</view>
        <view wx:if="{{selectedCouponName}}" class="text-muted">当前已选择：{{selectedCouponName}}</view>
      </view>
      <view wx:else class="text-muted">当前账单暂无可用券。</view>
    </view>

    <view class="panel card-stack">
      <view class="section-title">支付确认</view>
      <view class="chip-row channel-row">
        <view class="pill {{selectedChannel === 'WECHAT' ? 'pill-active' : ''}}" data-channel="WECHAT" bindtap="handleChannelSelect">微信支付</view>
        <view class="pill {{selectedChannel === 'ALIPAY' ? 'pill-active' : ''}}" data-channel="ALIPAY" bindtap="handleChannelSelect">支付宝支付</view>
      </view>
      <view class="info-list">
        <view class="info-row">
          <view class="info-key">当前房间</view>
          <view class="info-value">{{billDetail.roomLabel}}</view>
        </view>
        <view class="info-row">
          <view class="info-key">当前账期</view>
          <view class="info-value">{{billDetail.periodText}}</view>
        </view>
        <view class="info-row">
          <view class="info-key">应收金额</view>
          <view class="info-value">¥ {{billDetail.amountDueText}}</view>
        </view>
        <view class="info-row">
          <view class="info-key">优惠金额</view>
          <view class="info-value">¥ {{discountAmountText}}</view>
        </view>
        <view class="info-row">
          <view class="info-key">实付金额</view>
          <view class="info-value">¥ {{payAmountText}}</view>
        </view>
        <view class="info-row">
          <view class="info-key">支付渠道</view>
          <view class="info-value">{{selectedChannel === 'ALIPAY' ? '支付宝' : '微信'}}</view>
        </view>
      </view>
    </view>

    <view class="fixed-action-bar button-row">
      <view class="info-row action-summary-row">
        <view>
          <view class="info-key">实付金额</view>
          <view class="amount-secondary">¥ {{payAmountText}}</view>
        </view>
        <view wx:if="{{billDetail.status === 'PAID'}}" class="status-chip status-chip--PAID">已支付</view>
      </view>

      <button wx:if="{{billDetail.status !== 'PAID'}}" class="button-primary" bindtap="handlePay" loading="{{paying}}" disabled="{{paying || couponValidating}}">创建支付单并查看结果</button>
      <button wx:else class="button-secondary" bindtap="openPaymentResultFromPaid">查看支付结果</button>
    </view>
  </block>
</view>
