.page-shell {
  min-height: 100vh;
  padding: var(--page-padding);
  box-sizing: border-box;
}

.page-hero {
  padding: var(--space-4);
  margin-bottom: var(--space-4);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
}

.page-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  padding: 8rpx 16rpx;
  margin-bottom: var(--space-2);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-pill);
  background: var(--color-surface-muted);
  color: var(--color-text-secondary);
  font-size: var(--font-size-overline);
  font-weight: 500;
}

.page-title {
  font-size: var(--font-size-hero);
  font-weight: 700;
  line-height: var(--line-height-tight);
}

.page-subtitle {
  margin-top: var(--space-2);
  max-width: 34em;
  color: var(--color-text-secondary);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.panel {
  padding: var(--space-4);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-surface);
  box-shadow: var(--shadow-soft);
  box-sizing: border-box;
}

.panel + .panel {
  margin-top: var(--space-3);
}

.section-title {
  font-size: var(--font-size-title);
  font-weight: 700;
  line-height: var(--line-height-tight);
}

.section-subtitle {
  margin-top: var(--space-1);
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.section-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
}

.card-stack,
.list-stack {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 var(--space-3);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-surface-strong);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  box-sizing: border-box;
  color: var(--color-text);
  font-size: var(--font-size-body);
}

.picker-field {
  min-height: 88rpx;
  padding: 0 var(--space-3);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-surface-strong);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.picker-field__label {
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
}

.picker-field__value {
  color: var(--color-text);
  font-size: var(--font-size-body);
  font-weight: 500;
}

.textarea-input {
  min-height: 180rpx;
  padding-top: var(--space-3);
  padding-bottom: var(--space-3);
}

.state-card--success {
  border-color: var(--color-success);
  background: var(--color-success-soft);
}

.text-success {
  color: var(--color-success);
}

.button-primary,
.button-secondary,
.button-ghost,
.button-inline {
  margin: 0;
  border: none;
  border-radius: var(--radius-md);
  font-size: var(--font-size-body);
  font-weight: 600;
  box-sizing: border-box;
  transition: opacity 120ms ease, transform 120ms ease;
}

.button-primary::after,
.button-secondary::after,
.button-ghost::after,
.button-inline::after {
  border: none;
}

.button-primary {
  min-height: 96rpx;
  padding: 0 var(--space-4);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--button-primary-bg);
  color: var(--button-primary-text);
  box-shadow: var(--button-primary-shadow);
}

.button-secondary {
  min-height: 96rpx;
  padding: 0 var(--space-4);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--button-secondary-bg);
  color: var(--button-secondary-text);
  border: 1rpx solid var(--button-secondary-border);
}

.button-ghost {
  min-height: 96rpx;
  padding: 0 var(--space-4);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--button-ghost-bg);
  color: var(--button-ghost-text);
  border: 1rpx solid var(--button-ghost-border);
}

.button-inline {
  min-height: 68rpx;
  padding: 0 var(--space-3);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--button-inline-bg);
  color: var(--button-inline-text);
  border: 1rpx solid var(--button-inline-border);
}

button.button-primary,
button.button-secondary,
button.button-ghost,
button.button-inline {
  line-height: 1;
}

.button-primary.button-hover,
.button-secondary.button-hover,
.button-ghost.button-hover,
.button-inline.button-hover {
  opacity: 0.92;
  transform: scale(0.995);
}

.button-primary[disabled],
.button-secondary[disabled],
.button-ghost[disabled],
.button-inline[disabled] {
  opacity: 1;
  box-shadow: none;
}

.button-primary[disabled] {
  background: var(--button-primary-disabled-bg);
  color: var(--button-primary-disabled-text);
}

.button-secondary[disabled],
.button-ghost[disabled],
.button-inline[disabled] {
  background: var(--color-surface-muted);
  color: var(--color-text-muted);
  border-color: var(--color-border);
}

.button-row {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.chip-row,
.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.pill,
.coupon-chip {
  padding: 12rpx 22rpx;
  border-radius: var(--radius-pill);
  background: var(--color-surface-muted);
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  border: 1rpx solid transparent;
}

.pill-active {
  border-color: var(--color-border);
  background: var(--color-surface);
  color: var(--color-text);
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-3);
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.meta-label,
.info-key,
.text-muted,
.state-desc {
  color: var(--color-text-muted);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.meta-value,
.bill-card-title,
.room-card-title,
.state-title {
  color: var(--color-text);
  font-size: var(--font-size-subtitle);
  font-weight: 600;
}

.amount-primary {
  font-size: var(--font-size-hero);
  font-weight: 700;
  line-height: var(--line-height-tight);
}

.amount-secondary {
  font-size: var(--font-size-title);
  font-weight: 700;
}

.summary-pill {
  min-width: 152rpx;
  padding: var(--space-2) var(--space-3);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-surface);
  box-sizing: border-box;
}

.summary-pill__label {
  color: var(--color-text-muted);
  font-size: var(--font-size-overline);
}

.summary-pill__value {
  margin-top: var(--space-1);
  color: var(--color-text);
  font-size: var(--font-size-subtitle);
  font-weight: 700;
}

.action-panel--summary {
  gap: var(--space-2);
}

.action-panel__label {
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.action-panel__value {
  color: var(--color-text);
  font-size: var(--font-size-hero);
  font-weight: 700;
  line-height: var(--line-height-tight);
}

.action-panel__hint {
  color: var(--color-text-muted);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-2);
}

.metric-card {
  padding: var(--space-3);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-surface-strong);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  box-sizing: border-box;
}

.metric-label {
  color: var(--color-text-muted);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.metric-value {
  margin-top: var(--space-1);
  color: var(--color-text);
  font-size: var(--font-size-title);
  font-weight: 700;
  line-height: var(--line-height-tight);
}

.metric-note {
  margin-top: var(--space-1);
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
}

.surface-note {
  padding: var(--space-3);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-surface-muted);
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  line-height: var(--line-height-body);
  box-sizing: border-box;
}

.card-kicker {
  color: var(--color-primary);
  font-size: var(--font-size-overline);
  font-weight: 600;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
}

.info-value {
  color: var(--color-text);
  font-size: var(--font-size-body);
  text-align: right;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-size-caption);
  font-weight: 600;
}

.status-chip--ISSUED,
.status-chip--PAYING,
.status-chip--CREATED {
  color: var(--color-warning);
  background: var(--color-warning-soft);
}

.status-chip--PAID,
.status-chip--SUCCESS,
.status-chip--ACTIVE {
  color: var(--color-success);
  background: var(--color-success-soft);
}

.status-chip--FAILED,
.status-chip--INACTIVE,
.status-chip--CLOSED {
  color: var(--color-danger);
  background: var(--color-danger-soft);
}

.status-chip--PENDING,
.status-chip--ALL {
  color: var(--color-text-secondary);
  background: var(--color-info-soft);
}

.text-danger {
  color: var(--color-danger);
}

.divider {
  height: 1rpx;
  background: var(--divider-soft);
}

.state-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-2);
}

.safe-bottom {
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
}

.fixed-action-bar {
  position: sticky;
  bottom: 0;
  margin-top: var(--space-4);
  padding: var(--space-3);
  border-radius: var(--radius-lg);
  background: var(--fixed-overlay);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-floating);
}
