page {
  --page-background: #f7f8fa;
  --gradient-hero: none;
  --gradient-primary: none;
  --color-surface: #ffffff;
  --color-surface-strong: #ffffff;
  --color-surface-muted: #f3f4f6;
  --color-surface-overlay: #ffffff;
  --color-primary: #111827;
  --color-primary-deep: #111827;
  --color-primary-soft: #f3f4f6;
  --color-primary-border: #e5e7eb;
  --color-text: #111827;
  --color-text-contrast: #ffffff;
  --color-text-secondary: #4b5563;
  --color-text-muted: #6b7280;
  --color-border: #e5e7eb;
  --color-success: #166534;
  --color-success-soft: #ecfdf3;
  --color-warning: #b45309;
  --color-warning-soft: #fffbeb;
  --color-danger: #b91c1c;
  --color-danger-soft: #fef2f2;
  --color-info-soft: #f3f4f6;
  --shadow-card: none;
  --shadow-soft: none;
  --shadow-floating: none;
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 40rpx;
  --space-6: 48rpx;
  --page-padding: 32rpx;
  --radius-sm: 20rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;
  --radius-pill: 999rpx;
  --font-size-overline: 22rpx;
  --font-size-caption: 24rpx;
  --font-size-body: 28rpx;
  --font-size-subtitle: 32rpx;
  --font-size-title: 40rpx;
  --font-size-hero: 56rpx;
  --font-size-display: 72rpx;
  --line-height-body: 1.6;
  --line-height-tight: 1.25;
  background: var(--page-background);
  color: var(--color-text);
  font-family: "Source Han Sans SC", "PingFang SC", "Helvetica Neue", sans-serif;
}
