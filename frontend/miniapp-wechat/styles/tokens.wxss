page {
  --page-background: #f3f5f9;
  --gradient-hero: none;
  --gradient-primary: none;
  --color-surface: #ffffff;
  --color-surface-strong: #fcfdff;
  --color-surface-muted: #eef2f7;
  --color-surface-overlay: rgba(255, 255, 255, 0.9);
  --color-primary: #0f172a;
  --color-primary-deep: #111827;
  --color-primary-soft: #edf2f8;
  --color-primary-border: #d8e0eb;
  --color-accent: #2563eb;
  --color-accent-strong: #1e40af;
  --color-accent-soft: rgba(37, 99, 235, 0.12);
  --color-accent-ghost: rgba(37, 99, 235, 0.08);
  --color-text: #111827;
  --color-text-contrast: #ffffff;
  --color-text-secondary: #475569;
  --color-text-muted: #64748b;
  --color-border: #dce3ec;
  --color-success: #166534;
  --color-success-soft: #eafbf2;
  --color-warning: #b45309;
  --color-warning-soft: #fff7e6;
  --color-danger: #b91c1c;
  --color-danger-soft: #fef1f1;
  --color-info-soft: #eef2f7;
  --color-warning-border: rgba(245, 158, 11, 0.28);
  --fixed-overlay: rgba(243, 245, 249, 0.92);
  --button-primary-bg: #111827;
  --button-primary-text: #ffffff;
  --button-primary-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.16);
  --button-primary-disabled-bg: #cbd5e1;
  --button-primary-disabled-text: rgba(255, 255, 255, 0.84);
  --button-secondary-bg: rgba(255, 255, 255, 0.82);
  --button-secondary-text: #0f172a;
  --button-secondary-border: #d3dde8;
  --button-ghost-bg: transparent;
  --button-ghost-text: #475569;
  --button-ghost-border: rgba(148, 163, 184, 0.32);
  --button-inline-bg: #eef3f8;
  --button-inline-text: #0f172a;
  --button-inline-border: rgba(148, 163, 184, 0.18);
  --status-neutral-bg: #eef2f7;
  --status-neutral-text: #475569;
  --divider-soft: rgba(148, 163, 184, 0.18);
  --shadow-card: 0 20rpx 52rpx rgba(15, 23, 42, 0.07);
  --shadow-soft: 0 12rpx 28rpx rgba(15, 23, 42, 0.05);
  --shadow-floating: 0 -12rpx 40rpx rgba(15, 23, 42, 0.1);
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 40rpx;
  --space-6: 48rpx;
  --page-padding: 32rpx;
  --radius-sm: 20rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;
  --radius-pill: 999rpx;
  --font-size-overline: 22rpx;
  --font-size-caption: 24rpx;
  --font-size-body: 28rpx;
  --font-size-subtitle: 32rpx;
  --font-size-title: 40rpx;
  --font-size-hero: 56rpx;
  --font-size-display: 72rpx;
  --line-height-body: 1.6;
  --line-height-tight: 1.25;
  background: var(--page-background);
  color: var(--color-text);
  font-family: "Source Han Sans SC", "PingFang SC", "Helvetica Neue", sans-serif;
}

@media (prefers-color-scheme: dark) {
  page {
    --page-background: #060b14;
    --gradient-hero: none;
    --gradient-primary: none;
    --color-surface: rgba(13, 20, 32, 0.96);
    --color-surface-strong: rgba(18, 27, 42, 0.98);
    --color-surface-muted: rgba(25, 36, 54, 0.92);
    --color-surface-overlay: rgba(8, 13, 22, 0.92);
    --color-primary: #dbe7f5;
    --color-primary-deep: #f8fbff;
    --color-primary-soft: rgba(43, 60, 84, 0.86);
    --color-primary-border: rgba(95, 118, 149, 0.32);
    --color-accent: #8fb4ff;
    --color-accent-strong: #c7dcff;
    --color-accent-soft: rgba(143, 180, 255, 0.14);
    --color-accent-ghost: rgba(143, 180, 255, 0.12);
    --color-text: #f3f7fd;
    --color-text-contrast: #06101d;
    --color-text-secondary: #c3d0e0;
    --color-text-muted: #8ea0b5;
    --color-border: rgba(116, 136, 163, 0.24);
    --color-success: #7ee3a7;
    --color-success-soft: rgba(24, 70, 46, 0.44);
    --color-warning: #ffd27c;
    --color-warning-soft: rgba(110, 73, 18, 0.34);
    --color-danger: #ffb0b7;
    --color-danger-soft: rgba(105, 31, 44, 0.34);
    --color-info-soft: rgba(31, 45, 66, 0.88);
    --color-warning-border: rgba(255, 210, 124, 0.26);
    --fixed-overlay: rgba(7, 11, 19, 0.9);
    --button-primary-bg: #edf4ff;
    --button-primary-text: #06101d;
    --button-primary-shadow: 0 16rpx 38rpx rgba(2, 6, 23, 0.34);
    --button-primary-disabled-bg: rgba(74, 89, 111, 0.9);
    --button-primary-disabled-text: rgba(229, 238, 250, 0.62);
    --button-secondary-bg: rgba(17, 25, 39, 0.94);
    --button-secondary-text: #e7eef8;
    --button-secondary-border: rgba(129, 147, 172, 0.28);
    --button-ghost-bg: transparent;
    --button-ghost-text: #c3d0e0;
    --button-ghost-border: rgba(129, 147, 172, 0.22);
    --button-inline-bg: rgba(31, 45, 66, 0.96);
    --button-inline-text: #edf4ff;
    --button-inline-border: rgba(129, 147, 172, 0.2);
    --status-neutral-bg: rgba(31, 45, 66, 0.94);
    --status-neutral-text: #d5deea;
    --divider-soft: rgba(129, 147, 172, 0.14);
    --shadow-card: 0 24rpx 56rpx rgba(2, 6, 23, 0.42);
    --shadow-soft: 0 14rpx 30rpx rgba(2, 6, 23, 0.24);
    --shadow-floating: 0 -16rpx 42rpx rgba(2, 6, 23, 0.4);
  }
}
