page {
  --page-background: linear-gradient(180deg, #f5f9fd 0%, #eef4fb 52%, #f8fbfe 100%);
  --gradient-hero: linear-gradient(135deg, rgba(23, 92, 211, 0.14) 0%, rgba(255, 255, 255, 0.94) 62%, rgba(255, 255, 255, 0.98) 100%);
  --gradient-primary: linear-gradient(135deg, #2a6ee5 0%, #175cd3 55%, #0f4cb2 100%);
  --color-surface: rgba(255, 255, 255, 0.9);
  --color-surface-strong: #ffffff;
  --color-surface-muted: rgba(239, 245, 251, 0.9);
  --color-surface-overlay: rgba(255, 255, 255, 0.76);
  --color-primary: #175cd3;
  --color-primary-deep: #0f4cb2;
  --color-primary-soft: rgba(23, 92, 211, 0.12);
  --color-primary-border: rgba(23, 92, 211, 0.18);
  --color-text: #18344f;
  --color-text-contrast: #ffffff;
  --color-text-secondary: #62788f;
  --color-text-muted: #8a9aae;
  --color-border: rgba(142, 169, 196, 0.28);
  --color-success: #168f5a;
  --color-success-soft: rgba(22, 143, 90, 0.12);
  --color-warning: #c77400;
  --color-warning-soft: rgba(199, 116, 0, 0.12);
  --color-danger: #cf4d4d;
  --color-danger-soft: rgba(207, 77, 77, 0.12);
  --color-info-soft: rgba(86, 109, 137, 0.12);
  --shadow-card: 0 18rpx 44rpx rgba(20, 50, 84, 0.08);
  --shadow-soft: 0 12rpx 28rpx rgba(27, 63, 102, 0.06);
  --shadow-floating: 0 20rpx 48rpx rgba(18, 48, 82, 0.12);
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 40rpx;
  --space-6: 48rpx;
  --page-padding: 32rpx;
  --radius-sm: 20rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;
  --radius-pill: 999rpx;
  --font-size-overline: 22rpx;
  --font-size-caption: 24rpx;
  --font-size-body: 28rpx;
  --font-size-subtitle: 32rpx;
  --font-size-title: 40rpx;
  --font-size-hero: 56rpx;
  --font-size-display: 72rpx;
  --line-height-body: 1.6;
  --line-height-tight: 1.25;
  background: var(--page-background);
  color: var(--color-text);
  font-family: "Source Han Sans SC", "PingFang SC", "Helvetica Neue", sans-serif;
}
